  "item": [
    {
      "name": "Credit Notes",
      "description": "Credit notes management endpoints for StartUp Ventures",
      "item": [
        {
          "name": "Create Credit Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"clientName\": \"StartUp Ventures Inc\",\n  \"invoiceNumber\": \"INV-2024-SV-001\",\n  \"amount\": 15000,\n  \"status\": \"pending\",\n  \"dueDate\": \"2025-06-30T00:00:00Z\",\n  \"description\": \"Credit for service adjustment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/credit-notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "credit-notes"
              ]
            },
            "description": "Create a new credit note for StartUp Ventures Inc"
          },
          "response": []
        },
        {
          "name": "List Credit Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/credit-notes?clientId={{clientId}}&page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "credit-notes"
              ],
              "query": [
                {
                  "key": "clientId",
                  "value": "{{clientId}}",
                  "description": "Filter by client ID"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (starts at 1)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Records per page (max: 500)"
                }
              ]
            },
            "description": "List all credit notes for StartUp Ventures Inc"
