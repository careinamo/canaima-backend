{
  "info": {
    "_postman_id": "canaima-backend-api",
    "name": "Canaima Backend API",
    "description": "B2B credit and accounts-receivable serverless application API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Clients",
      "description": "Client management endpoints",
      "item": [
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/clients?page=1&limit=20&search=&status=&sortBy=createdAt&sortOrder=asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "clients"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (starts at 1)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Records per page (max: 500)"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search term (matches name or email)"
                },
                {
                  "key": "status",
                  "value": "",
                  "description": "Filter by status: active, inactive, overdue"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "description": "Field to sort by"
                },
                {
                  "key": "sortOrder",
                  "value": "asc",
                  "description": "Sort direction: asc or desc"
                }
              ]
            },
            "description": "Retrieve a paginated list of all clients for a given organization"
          },
          "response": []
        },
        {
          "name": "Get Client",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/clients/{{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "clients",
                "{{clientId}}"
              ]
            },
            "description": "Retrieve a specific client by ID within an organization"
          },
          "response": []
        },
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Client Corp\",\n  \"email\": \"contact@newclient.com\",\n  \"phone\": \"+1-555-0200\",\n  \"address\": \"500 Main St, Boston, MA 02101\",\n  \"status\": \"active\",\n  \"creditLimit\": 75000,\n  \"notes\": \"Referred by Acme Corporation\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/clients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "clients"
              ]
            },
            "description": "Create a new client account within an organization"
          },
          "response": []
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"overdue\",\n  \"creditLimit\": 100000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/clients/{{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "clients",
                "{{clientId}}"
              ]
            },
            "description": "Update one or more fields of an existing client"
          },
          "response": []
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{orgId}}/clients/{{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{orgId}}",
                "clients",
                "{{clientId}}"
              ]
            },
            "description": "Delete a client account"
          },
          "response": []
        }
      ]
    },
