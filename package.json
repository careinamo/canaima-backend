{
  "name": "canaima-backend",
  "version": "1.0.0",
  "description": "Canaima backend - Serverless Framework with TypeScript",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "serverless offline --stage dev",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "deploy:dev:oregon": "serverless deploy --stage dev --region us-west-2",
    "offline": "serverless offline",
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "seed:clients": "tsx src/seeds/clients.ts",
    "seed:credit-notes": "tsx src/seeds/credit-notes.ts",
    "seed:payments": "tsx src/seeds/payments.ts",
    "seed": "npm run seed:clients && npm run seed:credit-notes && npm run seed:payments"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "serverless": "^4.0.0",
    "serverless-offline": "^14.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
