# AWS Configuration
AWS_REGION=us-east-2
NODE_ENV=dev

# DynamoDB Tables
TABLE_CLIENTS_BASE=clients
TABLE_CREDIT_NOTES_BASE=credit-notes
TABLE_PAYMENTS_BASE=payments
TABLE_METRICS_BASE=metrics
TABLE_ORGANIZATIONS_BASE=organizations
TABLE_USERS_BASE=users
TABLE_WEBHOOK_EVENTS_BASE=webhook-events

# Clerk Configuration
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain

# Organization IDs for scheduled tasks
ORG_IDS=org-default

# Seed configuration
SEED_ORG_ID=org-default
